<ProxyEndpoint name="default">
    <PreFlow>
        <Request>
            <Step>
                <Name>AM-HelloResponse</Name>
            </Step>
            <Step>
                <Name>Q-Quota-Limit</Name>
            </Step>
        </Request>
        <Response/>
    </PreFlow>

    <Flows/>

    <HTTPProxyConnection>
        <BasePath>/v1/hello</BasePath>
    </HTTPProxyConnection>

    <RouteRule name="no-target"/>
</ProxyEndpoint>
